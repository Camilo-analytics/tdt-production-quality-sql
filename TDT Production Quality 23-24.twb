      <aliases enabled='yes' />
      <column caption='production cost' datatype='real' name='[Calculation_1699692003344384]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [unit_cost_aud]&gt;0 then [unit_cost_aud] ELSE 0 END' />
      </column>
      <column caption='Credits &amp; Returns' datatype='real' name='[Calculation_1699692003680257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [unit_cost_aud]&lt;0 then ABS([unit_cost_aud]) ELSE 0 END' />
      </column>
      <column caption='Net Cost' datatype='real' name='[Calculation_1699692004052994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[unit_cost_aud]' />
      </column>
      <column caption='Defect Rate' datatype='real' default-format='p0.00%' name='[Calculation_1699692010143747]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [inspection_result] = &apos;Fail&apos; or [inspection_result] = &quot;Rework&quot; then  1 ELSE 0 END) / COUNT([unit_id])' />
      </column>
      <column caption='Fails' datatype='integer' name='[Calculation_1699692020477956]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [inspection_result] = &quot;Fail&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Reworks' datatype='integer' name='[Calculation_1699692020764677]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [inspection_result]= &quot;Rework&quot; then 1 else 0 end)' />
      </column>
